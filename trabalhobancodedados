import androidx.room.RoomDatabase

@Database(
    entities = [Client::class, Product::class, Order::class, OrderProduct::class],
    version = 1,
    exportSchema = false
)
abstract class AppDatabase : RoomDatabase() {
    abstract fun clientDao(): ClientDao
    abstract fun productDao(): ProductDao
    abstract fun orderDao(): OrderDao
}
class ShopRepository(private val db: AppDatabase) {
    private val clientDao = db.clientDao()
    private val productDao = db.productDao()
    private val orderDao = db.orderDao()

    // Clientes
    fun getAllClients(): Flow<List<Client>> = clientDao.getAllClients()
    suspend fun insertClient(client: Client) = clientDao.insertClient(client)
    suspend fun updateClient(client: Client) = clientDao.updateClient(client)
    suspend fun deleteClient(client: Client) = clientDao.deleteClient(client)

    // Produtos
    fun getAllProducts(): Flow<List<Product>> = productDao.getAllProducts()
    suspend fun insertProduct(product: Product) = productDao.insertProduct(product)
    suspend fun updateProduct(product: Product) = productDao.updateProduct(product)
    suspend fun deleteProduct(product: Product) = productDao.deleteProduct(product)

    // Pedidos
    fun getAllOrders(): Flow<List<Order>> = orderDao.getAllOrders()
    suspend fun createOrder(order: Order, items: List<Pair<Product, Int>>): Long {
        val orderId = orderDao.insertOrder(order)
        items.forEach { (product, quantity) ->
            orderDao.insertOrderProduct(OrderProduct(orderId, product.id, quantity))
        }
        return orderId
    }

    fun getOrderWithProducts(orderId: Long): Flow<OrderWithProducts?> =
        orderDao.getOrderWithProducts(orderId)

    // Obter produtos com quantidades para um pedido específico (reativo)
    fun getProductsWithQuantityByOrder(orderId: Long): Flow<List<ProductWithQuantity>> =
        orderDao.getProductsWithQuantityByOrder(orderId)
}
class ShopViewModel(private val repository: ShopRepository) : ViewModel() {
    val allClients: LiveData<List<Client>> = repository.getAllClients().asLiveData()
    val allProducts: LiveData<List<Product>> = repository.getAllProducts().asLiveData()
    val allOrders: LiveData<List<Order>> = repository.getAllOrders().asLiveData()

    fun addClient(name: String, email: String, phone: String) {
        viewModelScope.launch {
            repository.insertClient(Client(name = name, email = email, phone = phone))
        }
    }

    fun placeOrder(clientId: Long, items: List<Pair<Product, Int>>) {
        viewModelScope.launch {
            val order = Order(
                clientId = clientId,
                date = System.currentTimeMillis(),
                status = "PENDING"
            )
            repository.createOrder(order, items)
        }
    }
}
class MyApp : Application() {
    lateinit var database: AppDatabase
        private set

    override fun onCreate() {
        super.onCreate()
        database = Room.databaseBuilder(
            applicationContext,
            AppDatabase::class.java,
            "shop_database"
        ).build()
    }
}
